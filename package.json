{
  "name": "yuri-chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite --host 127.0.0.1\" \"node server/index.mjs\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server/index.mjs",
    "backup:cloud-db": "node server/backup-cloud-db.mjs",
    "account:bootstrap-admin": "node server/bootstrap-admin-account.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "audit:architecture": "node scripts/architecture-audit.mjs",
    "test:agent": "node server/agentEval.mjs",
    "test:memory": "npx --yes tsx scripts/memoryEvalEntry.ts",
    "verify:all": "npm run lint && tsc -b && npm run audit:architecture && npm run test:agent && npm run test:memory",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
